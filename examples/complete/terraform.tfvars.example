# Copy to terraform.tfvars and edit. Only vault_address is required.
# Do NOT commit terraform.tfvars (it is gitignored).

# HCP Vault Dedicated cluster endpoint (placeholder — use your own):
vault_address = "https://<cluster>.private.vault.<cluster-uuid>.aws.hashicorp.cloud:8200"

# Optional overrides:
# vault_namespace = "admin"
# region          = "ap-southeast-1"
# name            = "example-secret-sync"
